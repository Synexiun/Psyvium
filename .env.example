# Root example env for VPSY OS. Copy to .env and to packages/database/.env / apps/api/.env
DATABASE_URL="postgresql://vpsy:vpsy@localhost:5432/vpsy?schema=public"
# JWT signing secrets — REQUIRED, min 16 chars. The API refuses to boot without them
# (there is no insecure code default). In production, generate strong random values,
# e.g. `openssl rand -base64 48`, and store them in your secret manager — never commit real ones.
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL=900
REDIS_URL="redis://localhost:6379"
# AI Gateway — activate-on-key. Set ANTHROPIC_API_KEY (or AI_GATEWAY_API_KEY) to run the
# real Claude model; with neither set the gateway returns a transparent rule-based note
# (never a fabricated AI result). Only de-identified structured signals are sent to the model.
ANTHROPIC_API_KEY=""
AI_GATEWAY_API_KEY=""
AI_MODEL="anthropic/claude-opus-4-8"
# Communications — activate-on-key. Set both to send real SMS via Twilio; with
# neither set, SMS uses the offline stub. Voice (click-to-call) still uses the
# stub until its status-callback webhook is wired (needs a public URL + number).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Payments (Stripe) — activate-on-key. Set STRIPE_SECRET_KEY to charge real
# PaymentIntents / create real Stripe Checkout Sessions; with it unset,
# POST /finance/invoices/:id/pay keeps using the offline/manual capture path
# (no PSP call, no fabricated success) and POST /finance/invoices/:id/checkout
# is unavailable. Set STRIPE_WEBHOOK_SECRET (from the Stripe Dashboard/CLI
# webhook endpoint you point at POST /finance/webhooks/stripe) to let that
# endpoint verify signatures and capture on checkout.session.completed —
# without it the webhook route rejects every request (it never trusts an
# unverified payload).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Observability (OpenTelemetry) — activate-on-config. Set OTEL_EXPORTER_OTLP_ENDPOINT
# (e.g. an OTel Collector at "http://localhost:4318") to export real traces+metrics
# there; with it unset, the API boots in no-op mode (no dial-out, console log only) —
# it never silently pretends to export. Traces/metrics never carry PHI: only ids,
# hashes, and classification tags (doc 10-observability-and-devops.md §7).
OTEL_EXPORTER_OTLP_ENDPOINT=""
WEB_ORIGIN="http://localhost:3000"
API_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
