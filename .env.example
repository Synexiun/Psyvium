# Root example env for VPSY OS. Copy to .env and to packages/database/.env / apps/api/.env
DATABASE_URL="postgresql://vpsy:vpsy@localhost:5432/vpsy?schema=public"
# JWT signing secrets — REQUIRED, min 16 chars. The API refuses to boot without them
# (there is no insecure code default). In production, generate strong random values,
# e.g. `openssl rand -base64 48`, and store them in your secret manager — never commit real ones.
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL=900
# Stateful refresh-session lifetime in seconds (default: 30 days). Each use
# rotates the token; replaced-token replay revokes the full session family.
JWT_REFRESH_TTL_SECONDS=2592000
REDIS_URL="redis://localhost:6379"
# AI Gateway — activate-on-key. Set ANTHROPIC_API_KEY (or AI_GATEWAY_API_KEY) to run the
# real Claude model; with neither set the gateway returns a transparent rule-based note
# (never a fabricated AI result). Only de-identified structured signals are sent to the model.
ANTHROPIC_API_KEY=""
AI_GATEWAY_API_KEY=""
AI_MODEL="anthropic/claude-opus-4-8"
# Communications — activate-on-key/config. Set TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN
# to send real SMS via Twilio; with either unset, SMS uses the offline stub.
# Voice (click-to-call) needs one more var, PUBLIC_API_URL, because voice is
# asynchronous — Twilio only originates the call synchronously and reports
# ringing/answered/completed later via a status-callback webhook
# (POST {PUBLIC_API_URL}/api/v1/comms/webhooks/twilio/voice-status), which
# must be reachable from the public internet (e.g. an ngrok tunnel in local
# dev, your real domain in production). With all three of TWILIO_ACCOUNT_SID,
# TWILIO_AUTH_TOKEN, and PUBLIC_API_URL set, click-to-call places a real
# outbound call and persists the CallSession as RINGING (no fabricated
# duration/outcome) until that webhook drives it to its true terminal state;
# with any one missing, click-to-call keeps using the offline stub (which
# still synchronously "completes" a 45s call, exactly as before — the demo
# stays fully offline-capable). See apps/api/src/modules/communications/
# adapters/twilio-voice.adapter.ts for the full call flow and
# webhooks/twilio-voice-webhook.controller.ts for the webhook's signature
# verification / tenant-binding design.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
PUBLIC_API_URL=""
# Payments (Stripe) — activate-on-key. Set STRIPE_SECRET_KEY to charge real
# PaymentIntents / create real Stripe Checkout Sessions; with it unset,
# POST /finance/invoices/:id/pay keeps using the offline/manual capture path
# (no PSP call, no fabricated success) and POST /finance/invoices/:id/checkout
# is unavailable. Set STRIPE_WEBHOOK_SECRET (from the Stripe Dashboard/CLI
# webhook endpoint you point at POST /finance/webhooks/stripe) to let that
# endpoint verify signatures and capture on checkout.session.completed —
# without it the webhook route rejects every request (it never trusts an
# unverified payload).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Telehealth (LiveKit Cloud) — activate-on-key. Set ALL THREE of
# LIVEKIT_API_KEY, LIVEKIT_API_SECRET, and LIVEKIT_URL (e.g.
# "wss://your-project.livekit.cloud") to mint real, room-scoped,
# identity-bound, short-TTL (15 min) join tokens for POST /telehealth/
# sessions/:id/join and .../admit (doc 08-telehealth-and-realtime.md §14).
# With any one missing, those endpoints return 503 VIDEO_NOT_CONFIGURED —
# never a fabricated token that connects nowhere. The waiting-room
# transition (client join before admit) needs no LiveKit call at all, so it
# still works offline. See apps/api/src/modules/telehealth/adapters/
# livekit.adapter.ts.
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
LIVEKIT_URL=""
# Observability (OpenTelemetry) — activate-on-config. Set OTEL_EXPORTER_OTLP_ENDPOINT
# (e.g. an OTel Collector at "http://localhost:4318") to export real traces+metrics
# there; with it unset, the API boots in no-op mode (no dial-out, console log only) —
# it never silently pretends to export. Traces/metrics never carry PHI: only ids,
# hashes, and classification tags (doc 10-observability-and-devops.md §7).
OTEL_EXPORTER_OTLP_ENDPOINT=""
# Field-level PHI encryption (docs/technical/06-security-and-rbac.md §7) — activate-on-config.
# Set VPSY_FIELD_KEY to a 32-byte key, base64-encoded, e.g. generate one with:
#   openssl rand -base64 32
# With it set, MFA/TOTP secrets, SessionNote.content and every PHI-Critical SafetyPlan field (warningSigns,
# copingStrategies, supportContacts, professionalContacts, distractionContacts, helpContacts,
# crisisLineInfo, meansRestriction, environmentSafety) are encrypted at rest with app-managed
# libsodium XChaCha20-Poly1305, AAD-bound to tenantId (an envelope moved across tenants fails
# to decrypt — defense-in-depth on top of tenantId scoping + RLS). With it unset in local/dev/test,
# those fields stay cleartext (never half-encrypted). In production NODE_ENV=production the API
# FAILS FAST without VPSY_FIELD_KEY unless you deliberately set VPSY_ALLOW_PLAINTEXT_PHI=true
# (non-PHI demos only). If set but not valid base64 or not exactly 32 bytes decoded, the API
# fails fast at boot (same contract as JWT secrets).
VPSY_FIELD_KEY=""
# Optional key id written into new envelopes (default v1). For rotation:
# set VPSY_FIELD_KEY to the NEW key, VPSY_FIELD_KEY_ID=v2, and keep the old key as
# VPSY_FIELD_KEY_PREVIOUS (+ optional VPSY_FIELD_KEY_PREVIOUS_ID=v1) for decrypt-only.
VPSY_FIELD_KEY_ID=""
VPSY_FIELD_KEY_PREVIOUS=""
VPSY_FIELD_KEY_PREVIOUS_ID=""
# Field key provider: unset/env = VPSY_FIELD_KEY; kms = unwrap VPSY_FIELD_DEK_CIPHERTEXT via AWS KMS.
VPSY_FIELD_KEY_PROVIDER=""
VPSY_FIELD_DEK_CIPHERTEXT=""
VPSY_KMS_ENDPOINT=""
VPSY_ALLOW_PLAINTEXT_PHI=""
# Documents metadata-only path (no blob storage / malware scan yet). Disabled in production
# unless this is explicitly "true" for a controlled demo.
VPSY_ALLOW_DOCUMENT_METADATA_ONLY=""
# Document blob backend: unset = disabled/metadata-only; "local" = filesystem staging;
# "s3" = AWS S3 / MinIO (requires AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION, VPSY_DOCUMENT_S3_BUCKET).
VPSY_DOCUMENT_BLOB_BACKEND=""
VPSY_DOCUMENT_LOCAL_DIR=""
VPSY_DOCUMENT_SIGNING_SECRET=""
VPSY_DOCUMENT_S3_BUCKET=""
VPSY_DOCUMENT_S3_ENDPOINT=""
VPSY_DOCUMENT_S3_FORCE_PATH_STYLE=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
AWS_SESSION_TOKEN=""
# Malware scan worker: true enables background sweep. STUB marks clean (staging only).
# With CLAMAV_HOST + local or s3 blob backend, worker loads object bytes and streams zINSTREAM.
VPSY_DOCUMENT_VIRUS_SCAN=""
VPSY_DOCUMENT_VIRUS_SCAN_STUB=""
VPSY_ALLOW_VIRUS_SCAN_STUB_IN_PROD=""
VPSY_DOCUMENT_VIRUS_SCAN_MAX_BYTES="26214400"
CLAMAV_HOST=""
CLAMAV_PORT="3310"
# Daily audit chain tip anchor (UTC midnight). Set false to disable cron; verify still available via API.
VPSY_AUDIT_DAILY_ANCHOR=""
# SIEM / security export (activate-on-config; PHI-minimized JSON). Either channel optional.
# Webhook: POST application/json; optional HMAC-SHA256 in X-VPSY-Signature: sha256=<hex>
VPSY_SIEM_WEBHOOK_URL=""
VPSY_SIEM_WEBHOOK_SECRET=""
VPSY_SIEM_WEBHOOK_TIMEOUT_MS="5000"
# Append-only JSONL per day (staging / air-gapped stand-in for WORM until Object Lock).
VPSY_SIEM_LOCAL_DIR=""
# Transactional email (password reset, invites, DPO alerts). Activate-on-key:
# set RESEND_API_KEY + EMAIL_FROM for live delivery; otherwise console-only.
RESEND_API_KEY=""
EMAIL_FROM=""
DPO_ALERT_EMAIL=""
# Manager minimum-necessary PHI: when "true", managers need break-glass for client PHI
# (default off = tenant-wide manager ops access).
VPSY_MANAGER_MINIMUM_NECESSARY=""
# Expose /api/docs Swagger in production (off by default when NODE_ENV=production).
VPSY_ENABLE_SWAGGER=""
# Production multi-instance: REDIS_URL is required unless this is set true for a
# deliberate single-instance demo (in-memory rate-limit/idempotency only).
VPSY_ALLOW_INMEMORY_RATE_LIMIT=""
# SMS quiet hours (UTC). Default 21:00–08:00. Set DISABLED=true for emergency-only bypass.
VPSY_SMS_QUIET_HOURS_START="21"
VPSY_SMS_QUIET_HOURS_END="8"
VPSY_SMS_QUIET_HOURS_DISABLED=""
# Payout bank-rail disbursement (not implemented). Keep unset so
# POST /finance/payouts/:id/disburse returns 503 honestly.
VPSY_ALLOW_PAYOUT_DISBURSE=""
# Key retrieval goes through a FieldKeyProvider seam (apps/api/src/common/crypto/
# field-key-provider.ts) — swapping this env-var-backed EnvFieldKeyProvider for a future
# AWS KMS-backed provider (decrypt a wrapped DEK via KMS on boot, same Buffer contract) is a
# single DI binding change in field-cipher.module.ts; no call site in clinical-documentation
# or risk touches key material directly. Never commit a real value — dev/demo only below.
VPSY_FIELD_KEY=""
WEB_ORIGIN="http://localhost:3000"
API_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
