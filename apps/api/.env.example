# VPSY API environment
NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://vpsy:vpsy@localhost:5432/vpsy?schema=public"
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL=900
REDIS_URL="redis://localhost:6379"
# AI Gateway (Vercel AI Gateway). If unset, the AI Gateway runs in deterministic offline stub mode.
AI_GATEWAY_API_KEY=""
AI_MODEL="anthropic/claude-opus-4-8"
# Communications (Twilio) — activate-on-key/config; see root .env.example for the full note.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Voice (click-to-call) additionally needs a publicly reachable status-callback URL.
PUBLIC_API_URL=""
# Payments (Stripe) — activate-on-key; see root .env.example for the full note.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Observability (OpenTelemetry) — activate-on-config; see root .env.example for the full note.
OTEL_EXPORTER_OTLP_ENDPOINT=""
# Field-level PHI encryption (docs/technical/06-security-and-rbac.md §7) — activate-on-config;
# see root .env.example for the full note. Generate a dev/demo key with: openssl rand -base64 32
VPSY_FIELD_KEY=""
WEB_ORIGIN="http://localhost:3000"
