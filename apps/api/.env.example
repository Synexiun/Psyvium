# VPSY API environment
NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://vpsy:vpsy@localhost:5432/vpsy?schema=public"
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL=900
REDIS_URL="redis://localhost:6379"
# AI Gateway (Vercel AI Gateway). If unset, the AI Gateway runs in deterministic offline stub mode.
AI_GATEWAY_API_KEY=""
AI_MODEL="anthropic/claude-opus-4-8"
# Payments (Stripe) — activate-on-key; see root .env.example for the full note.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Observability (OpenTelemetry) — activate-on-config; see root .env.example for the full note.
OTEL_EXPORTER_OTLP_ENDPOINT=""
WEB_ORIGIN="http://localhost:3000"
